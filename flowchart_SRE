flowchart TB
 subgraph Orchestration_Layer["Orchestration Layer"]
        Orch{"Orchestrator Node"}
        Gov("Governance and Safety Agent")
        Doc("Documentation Agent")
  end
 subgraph External_Federation["External Agent Federation - A2A Protocol"]
        A2A{{"A2A Gateway / Adapter"}}
        Cortex["Cortex Ops Agent<br>existing external system"]
        FuturePlug[/"Reserved Interface<br>for future external agents"/]
  end
 subgraph Domain_Agents["DomainAgents / Brains"]
        Triage("Triage and Ingestion Agent")
        CompBrain("Compute DomainAgent")
        NetBrain("Network DomainAgent")
        StoreBrain("Storage DomainAgent")
        PlatBrain("Platform DomainAgent")
  end
 subgraph Memory_Architecture["Memory Architecture"]
        Episodic[("Episodic Memory<br>Redis - Active State")]
        Semantic[("Semantic Memory<br>VectorDB - RAG / Postmortems")]
        Config[("Config Memory<br>PostgreSQL - RBAC / Rules")]
  end
 subgraph Operators["Deterministic Operators / Hands"]
        CompHand["Compute Operator<br>Node/Pod scaling"]
        NetHand["Network Operator<br>OVN/Policies"]
        StoreHand["Storage Operator<br>Ceph/OSD"]
        PlatHand["Platform Operator<br>Upgrades/Certs"]
  end
    Alert["🚨 Alert / Telemetry Spike"] --> Gate["MCP Gateway Bus<br>Tool and Data Router"]
    ACM["ACM api"] --> Gate
    GitOps_Api["GitOps api"] --> Gate
    
    Obs[("Observability APIs<br>Datadog / Prometheus")] --> Gate
    Topo[("Service Mesh Topology")] --> Gate
    Gate --> Orch
    Orch --> Gov & Doc & Triage & CompBrain & NetBrain & StoreBrain & PlatBrain
    A2A <--> Cortex
    A2A -. reserved, unconnected today .-> FuturePlug
    Orch <--> A2A & Episodic
    CompBrain <--> Semantic
    NetBrain <--> Semantic
    StoreBrain <--> Semantic
    PlatBrain <--> Semantic
    Gov <--> Config
    Doc --> Semantic
    Triage --> Gate2["MCP Gateway Bus<br>Action Router"]
    CompBrain --> Gate2
    NetBrain --> Gate2
    StoreBrain --> Gate2
    PlatBrain --> Gate2
    Gov --> Gate2
    Gate2 --> HITL{"Human-in-the-Loop<br>Slack / PagerDuty"}
    HITL -- Approved Action --> CompHand & NetHand & StoreHand & PlatHand
    HITL -- Denied / Manual Intervention --> Orch
    CompHand --> Verify("Execution Validation Agent")
    NetHand --> Verify
    StoreHand --> Verify
    PlatHand --> Verify
    Verify -- Confirmed Resolved --> Doc
    Verify -- Regressed / Not Fixed --> Orch

