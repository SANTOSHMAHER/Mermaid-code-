graph TD
    %% External Triggers
    Alert[🚨 Alert / Telemetry Spike]:::sky --> Gate[MCP Gateway Bus]:::orange
    
    %% Core Orchestration
    subgraph Orchestration Layer
        Orch{Orchestrator Node}:::indigo
        Gov(Governance & Safety Agent):::red
        Doc(Documentation Agent):::red
        
        %% Initial Alert Routing
        Orch --> Gov
        Orch --> Doc
    end

    %% The Domain Brains (Diagnostic AI)
    subgraph DomainAgents / Brains
        Triage(Triage & Ingestion Agent):::teal
        CompBrain(Compute DomainAgent):::teal
        NetBrain(Network DomainAgent):::teal
        StoreBrain(Storage DomainAgent):::teal
        PlatBrain(Platform DomainAgent):::teal
        
        %% Routing from Orchestrator based on Context
        Orch --> Triage
        Orch --> CompBrain
        Orch --> NetBrain
        Orch --> StoreBrain
        Orch --> PlatBrain
    end

    %% The Memory Architecture
    subgraph Memory Architecture
        Episodic[(Episodic Memory<br>Redis - Active State)]:::violet
        Semantic[(Semantic Memory<br>VectorDB - RAG/Post-mortems)]:::violet
        Config[(Config Memory<br>PostgreSQL - RBAC/Rules)]:::violet
    end

    %% Memory Binding
    Orch <--> Episodic
    CompBrain <--> Semantic
    NetBrain <--> Semantic
    StoreBrain <--> Semantic
    PlatBrain <--> Semantic
    Gov <--> Config
    Doc --> Semantic

    %% Execution Boundary
    subgraph Execution Boundary
        Gate[MCP Gateway Bus / API Router]:::orange
    end

    %% Routing AI Decisions to the Gateway
    Triage --> Gate
    CompBrain --> Gate
    NetBrain --> Gate
    StoreBrain --> Gate
    PlatBrain --> Gate
    Gov --> Gate

    %% The HITL Gate (Safety)
    Gate --> HITL{Human-in-the-Loop<br>Slack / PagerDuty}:::red

    %% The Deterministic Operators (Hands)
    subgraph Deterministic Operators / Hands
        CompHand[Compute Operator<br>Node/Pod scaling]:::green
        NetHand[Network Operator<br>OVN/Policies]:::green
        StoreHand[Storage Operator<br>Ceph/OSD]:::green
        PlatHand[Platform Operator<br>Upgrades/Certs]:::green
    end

    %% Secure Execution Flow
    HITL -- Approved Action --> CompHand
    HITL -- Approved Action --> NetHand
    HITL -- Approved Action --> StoreHand
    HITL -- Approved Action --> PlatHand
    
    %% Loop back if Denied
    HITL -- Denied / Manual Intervention --> Orch

    %% Observability Inputs
    Gate --> Obs[Observability APIs<br>Datadog / Prometheus]:::sky
    Gate --> Topo[Service Mesh Topology]:::sky
    
    %% Closing the Loop
    CompHand --> Doc
    NetHand --> Doc
    StoreHand --> Doc
    PlatHand --> Doc

    %% Color Definitions
    classDef indigo stroke:#818cf8,fill:#eef2ff;
    classDef teal stroke:#2dd4bf,fill:#f0fdfa;
    classDef violet stroke:#a78bfa,fill:#f5f3ff;
    classDef orange stroke:#fb923c,fill:#fff7ed;
    classDef red stroke:#f87171,fill:#fef2f2;
    classDef green stroke:#4ade80,fill:#f0fdf4;
    classDef sky stroke:#38bdf8,fill:#f0f9ff;
